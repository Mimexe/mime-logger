{
  "name": "mime-logger",
  "version": "2.0.1",
  "description": "A simple logger for Node.js",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "bun run clean && bun run build.ts",
    "clean": "rimraf dist",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "bugs": {
    "url": "https://github.com/Mimexe/mime-logger/issues",
    "email": "mime+bugs@mimedev.fr"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mimexe/mime-logger.git"
  },
  "homepage": "https://github.com/Mimexe/mime-logger#readme",
  "keywords": [
    "cli",
    "logger"
  ],
  "type": "module",
  "author": "Mime <mime@mimedev.fr> (https://mimedev.fr)",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "bun-plugin-dts": "^0.4.0",
    "cross-env": "^10.1.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "chalk": "5.6.2"
  },
  "files": [
    "dist/index.js",
    "dist/index.cjs",
    "dist/index.d.ts"
  ]
}
